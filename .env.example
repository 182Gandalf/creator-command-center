# FlowCast Environment Variables
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to GitHub!

# Flask Secret Key
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Google OAuth 2.0 Credentials
# Get from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# YouTube API Key
# Get from Google Cloud Console > APIs & Services > Credentials > API Keys
YOUTUBE_API_KEY=your-youtube-api-key

# TikTok API Credentials
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# Meta/Instagram API Credentials
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# Paddle Payment Integration
PADDLE_VENDOR_ID=your-paddle-vendor-id
PADDLE_API_KEY=your-paddle-api-key
PADDLE_PUBLIC_KEY=your-paddle-public-key

# Gemini AI API Key
GEMINI_API_KEY=your-gemini-api-key

# Database URL (Railway provides this automatically)
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# Redis URL (for caching/sessions)
# REDIS_URL=redis://localhost:6379/0

# Email Configuration (ProtonMail via Bridge)
# PROTON_BRIDGE_PASSWORD=your-bridge-generated-password

# Google Search Console Verification
GOOGLE_SEARCH_CONSOLE_VERIFICATION=your-verification-code

# Development Settings
FLASK_ENV=development
FLASK_DEBUG=True

# Production Settings (uncomment for production)
# FLASK_ENV=production
# FLASK_DEBUG=False
